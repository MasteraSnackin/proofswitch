{
  "name": "proofswitch-prototype",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://proofswitch.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/MasteraSnackin/proofswitch.git"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/*.test.*",
    "test:unit": "node --test tests/*.test.*",
    "agent": "tsx scripts/run-agent.ts",
    "demo:voices": "node --env-file-if-exists=.env.local scripts/elevenlabs-demo.mjs --list-voices",
    "demo:elevenlabs:check": "node --env-file-if-exists=.env.local scripts/elevenlabs-demo.mjs --dry-run",
    "demo:elevenlabs": "node --env-file-if-exists=.env.local scripts/elevenlabs-demo.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@solana/web3.js": "1.98.4",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@cloudflare/workers-types": "5.20260715.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.111.0"
  },
  "type": "module"
}
