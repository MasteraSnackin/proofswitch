# ProofSwitch defaults to its deterministic, credential-free demonstration.
PROOFSWITCH_MODE=synthetic

# Switch to live only after an activated TxLINE token is available.
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_API_TOKEN=
# Keep false unless a controlled local TxLINE-compatible test endpoint is used.
TXLINE_ALLOW_CUSTOM_ORIGIN=false

# Required only in live mode. The code is entered by an operator or judge;
# the independent signing secret protects the short-lived HttpOnly session
# cookie. Generate both values independently and keep them server-side.
# Synthetic mode does not require either value.
PROOFSWITCH_ACCESS_CODE=
PROOFSWITCH_ACCESS_SIGNING_SECRET=
PROOFSWITCH_ACCESS_SESSION_TTL_SECONDS=3600

# Best-effort safeguards for each running server isolate. They reduce accidental
# load and simple abuse, but are not a globally coordinated rate-limit service.
PROOFSWITCH_ACCESS_ATTEMPTS_PER_MINUTE=5
PROOFSWITCH_LIVE_REQUESTS_PER_MINUTE=120
PROOFSWITCH_LIVE_MAX_CONCURRENT_REQUESTS=16
PROOFSWITCH_LIVE_MAX_CONCURRENT_STREAMS=4
PROOFSWITCH_LIVE_MAX_STREAM_DURATION_MS=900000

# Optional: preselect one returned fixture. The fixture catalogue remains the
# runtime source of truth, so do not hard-code a competition ID.
TXLINE_FIXTURE_ID=

# Live policy. Transport freshness is measured from SSE data or heartbeat
# receipt, not from whether a market price changed.
PROOFSWITCH_TRANSPORT_STALE_AFTER_MS=20000
PROOFSWITCH_SHOCK_WINDOW_MS=2000
PROOFSWITCH_SHOCK_DELTA=0.04
PROOFSWITCH_PRICE_SILENCE_MS=120000
PROOFSWITCH_PRICE_SOURCE_AGE_MS=120000
PROOFSWITCH_MINIMUM_SUSPEND_MS=3000
PROOFSWITCH_STABLE_OBSERVATIONS=3
PROOFSWITCH_STABLE_DELTA=0.0075
PROOFSWITCH_MAXIMUM_LIABILITY=1000
PROOFSWITCH_REQUOTE_DELTA=0.005
PROOFSWITCH_MINIMUM_REQUOTE_INTERVAL_MS=1000

# Read-only Solana validation target. Proof retrieval can be enabled once the
# TxLINE token is configured; no private key belongs in this web application.
SOLANA_RPC_URL=https://api.devnet.solana.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
SOLANA_VALIDATION_ENABLED=false
# Public address only. Use an existing funded, non-executable devnet System
# Program account so simulation has a valid fee payer. Never put a private key,
# seed phrase or wallet file here.
SOLANA_SIMULATION_PAYER_PUBLIC_KEY=
